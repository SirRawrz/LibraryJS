<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>Albums — Platform-aware Uploads</title>
<style>
:root{--bg:#071019;--panel:#0b1720;--card:#0f2230;--muted:#9aa4b2;--accent:#66d0e8;--white:#f7fafc}
*{box-sizing:border-box}
body{margin:0;font-family:Inter,system-ui,Arial;color:var(--white);background:linear-gradient(180deg,var(--bg),#03121a);padding:14px}
.wrap{max-width:1200px;margin:0 auto}
.topbar{display:flex;align-items:center;gap:12px;margin-bottom:12px}
.topbar .right{margin-left:auto;display:flex;gap:8px;align-items:center}
.profile-badge{display:flex;align-items:center;gap:8px;background:rgba(255,255,255,0.02);padding:6px;border-radius:18px;cursor:pointer}
.profile-badge img{width:36px;height:36px;border-radius:8px;object-fit:cover;border:2px solid transparent}
.profile-badge img.active{border-color:var(--accent)}
h1{margin:0;font-size:18px}
.layout{display:flex;gap:20px;align-items:flex-start}
.sidebar{width:320px;background:rgba(255,255,255,0.02);padding:14px;border-radius:10px}
.main{flex:1;background:rgba(255,255,255,0.02);padding:14px;border-radius:10px}
.nav-group{margin-bottom:14px}
.nav-group h3{margin:0 0 8px 6px;font-size:12px;color:var(--muted);text-transform:uppercase}
.nav-item{display:flex;align-items:center;gap:10px;padding:8px 10px;border-radius:8px;color:var(--muted);cursor:pointer}
.nav-item:hover{background:rgba(255,255,255,0.03);color:var(--white)}
.nav-item.active{background:var(--accent);color:#041616;font-weight:800}
.btn-create{width:100%;padding:10px;border:1px dashed rgba(102,208,232,0.3);color:var(--accent);border-radius:8px;background:transparent;cursor:pointer}
.controls{display:flex;align-items:center;gap:12px;justify-content:space-between}
.search-box{background:var(--panel);border:1px solid rgba(255,255,255,0.06);padding:8px 12px;border-radius:20px;color:#fff;outline:none}
.photo-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:14px;margin-top:12px}
.photo-card{background:var(--card);border-radius:12px;overflow:hidden;position:relative;aspect-ratio:1/1;display:flex;flex-direction:column}
.photo-card img{width:100%;height:100%;object-fit:cover;display:block}
.card-actions{position:absolute;bottom:8px;left:8px;right:8px;display:flex;justify-content:space-between;gap:8px}
.action-btn{background:rgba(255,255,255,0.08);border:none;color:#fff;padding:8px;border-radius:8px;cursor:pointer;font-weight:700}
.action-btn.ghost{background:transparent;border:1px solid rgba(255,255,255,0.04)}
.muted{color:var(--muted);font-size:13px}
.empty{padding:14px;border-radius:8px;background:rgba(255,255,255,0.01);color:var(--muted)}
.uploader{margin-top:12px;padding-top:8px;border-top:1px dashed rgba(255,255,255,0.02)}
.staged-grid{display:flex;gap:8px;flex-wrap:wrap;margin-top:8px}
.staged-tile{width:84px;height:84px;border-radius:8px;overflow:hidden;background:rgba(255,255,255,0.02);display:flex;align-items:center;justify-content:center}
.staged-tile img{width:100%;height:100%;object-fit:cover}
#sys-toast{position:fixed;right:20px;bottom:20px;background:#000;padding:10px 14px;border-radius:8px;color:#fff;display:none;z-index:9999;border-left:4px solid var(--accent)}
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.6);display:none;align-items:center;justify-content:center;z-index:999}
.modal{background:var(--panel);padding:18px;border-radius:10px;width:360px}
small.note{display:block;color:var(--muted);margin-top:10px}
.method-badge{font-size:12px;color:var(--muted);margin-left:8px}
@media(max-width:900px){.layout{flex-direction:column}.sidebar{width:100%}}
</style>
</head>
<body>
<div class="wrap">
  <div class="topbar">
    <div style="display:flex;gap:12px;align-items:center">
      <h1>Albums</h1>
      <div class="profile-badge" id="gotoIndex" title="Go to index" onclick="location.href='index.html'">
        <img id="activeProfileIcon" src="favicon.ico" alt="profile">
        <div id="activeProfileName" style="font-weight:800">Guest</div>
      </div>
    </div>
    <div class="right">
      <div class="method-badge" id="detectedMethod">platform: —</div>
      <button class="action-btn ghost" onclick="refreshAll()">Refresh</button>
      <button class="action-btn" onclick="document.getElementById('fileInput').click()">Add Photos</button>
      <input id="fileInput" type="file" accept="image/*" multiple style="display:none" onchange="handleUpload(this)">
    </div>
  </div>

  <div class="layout">
    <div class="sidebar">
      <div>
        <label style="font-size:12px;color:var(--muted)">Active profile</label>
        <div style="margin-top:8px;font-weight:800" id="activeProfileLabel">Guest</div>
      </div>

      <div class="nav-group">
        <h3>Library</h3>
        <div class="nav-item active" id="nav-all" onclick="setView('all')">🖼️ All Photos</div>
      </div>

      <div class="nav-group">
        <h3>My Albums</h3>
        <div id="my-albums-list"></div>
        <button class="btn-create" onclick="createAlbumModal()">+ Create New Album</button>
      </div>

      <div class="nav-group">
        <h3>Shared</h3>
        <div id="shared-albums-list"></div>
        <small class="muted">Shared images live in <code>/Albums/shared/</code> as <code>Profile-Filename.ext</code></small>
      </div>

      <div class="uploader">
        <label style="font-size:12px;color:var(--muted)">Staged uploads</label>
        <div id="stagedCount" class="muted" style="margin-top:6px">No files staged</div>
        <div class="staged-grid" id="stagedGrid"></div>
        <div style="display:flex;gap:8px;margin-top:8px">
          <button class="action-btn" id="commitUploadsBtn" onclick="commitUploads()">Commit uploads</button>
          <button class="action-btn ghost" onclick="clearStaged()">Clear</button>
        </div>
        <small class="note">Staged uploads are previewed locally first. Uploads will attempt to use the server's configured method (see platform.txt).</small>
      </div>
    </div>

    <div class="main">
      <div class="controls">
        <h2 id="viewTitle" style="margin:0;font-size:20px">All Photos</h2>
        <input id="searchInput" class="search-box" placeholder="Search photos..." oninput="filterGrid(this.value)">
      </div>

      <div id="photosArea">
        <div id="photos" class="photo-grid"></div>
      </div>
    </div>
  </div>
</div>

<!-- modal -->
<div class="modal-overlay" id="modalOverlay">
  <div class="modal">
    <h3 id="modalHeading">Create Album</h3>
    <input id="modalInput" placeholder="Album name" style="width:100%;padding:8px;border-radius:6px;border:1px solid rgba(255,255,255,0.04);background:transparent;color:#fff" />
    <div style="display:flex;justify-content:flex-end;gap:8px;margin-top:12px">
      <button class="action-btn ghost" onclick="closeModal()">Cancel</button>
      <button class="action-btn" id="modalSaveBtn">Save</button>
    </div>
  </div>
</div>

<div id="sys-toast"></div>

<script>
/* Albums — platform.txt-aware uploads with Windows default
   - Reads ./platform.txt (no-store) and falls back to window.SERVER_UPLOAD_STYLE/window.detectedPlatform/local default 'windows'
   - Uses same upload strategies as radio.html/Music.html: putFileByPUT, /api/file/upload?path=, /pocketserver-api/upload
   - On success updates album JSON and master library so images appear instantly
*/

const AlbumsRoot = '/Albums/';
const IMAGE_RE = /\.(jpe?g|png|gif|webp|avif|heic)$/i;
const PROFILE_KEYS = ['activeProfile','chosenProfile','selectedProfile','profile','activeProfileName'];

function $id(id){ return document.getElementById(id); }
function toast(msg, t=2200){ const el=$id('sys-toast'); el.textContent=msg; el.style.display='block'; setTimeout(()=>el.style.display='none', t); }

/* ---------- profile helpers ---------- */
function getStoredProfile(){
  if (typeof window.activeProfile === 'string' && window.activeProfile) return window.activeProfile;
  for (const k of PROFILE_KEYS){
    try { const v = localStorage.getItem(k); if (v) return v; } catch(e){}
  }
  return 'Guest';
}
function persistProfile(name){
  for (const k of PROFILE_KEYS){
    try { if (localStorage.getItem(k) !== null) { localStorage.setItem(k, name); return; } } catch(e){}
  }
  try { localStorage.setItem(PROFILE_KEYS[0], name); } catch(e){}
  try { window.activeProfile = name; } catch(e){}
}

/* ---------- state ---------- */
let activeProfile = getStoredProfile();
let profiles = [];
let masterLibrary = []; // absolute-ish paths to images
let customAlbums = [];
let stagedUploads = []; // {file, previewUrl}
let currentView = 'all';

/* ---------- platform detection (cached) ---------- */
async function detectPlatform(){
  if (window.__albums_detectedPlatform) return window.__albums_detectedPlatform;
  // 1) try platform.txt (no-store)
  try {
    const r = await fetch('./platform.txt', { cache: 'no-store' });
    if (r && r.ok) {
      const txt = (await r.text()).trim().toLowerCase();
      if (txt) { window.__albums_detectedPlatform = txt; updateMethodBadge(txt); return txt; }
    }
  } catch(e){ /* ignore */ }

  // 2) check global overrides (other pages set this)
  const globalChoices = [window.SERVER_UPLOAD_STYLE, window.detectedPlatform];
  for (const g of globalChoices){
    if (typeof g === 'string' && g.trim()) { window.__albums_detectedPlatform = g.trim().toLowerCase(); updateMethodBadge(window.__albums_detectedPlatform); return window.__albums_detectedPlatform; }
  }

  // 3) fallback to saved local override if present
  try {
    const saved = localStorage.getItem('server_upload_platform');
    if (saved) { window.__albums_detectedPlatform = saved.toLowerCase(); updateMethodBadge(window.__albums_detectedPlatform); return window.__albums_detectedPlatform; }
  } catch(e){}

  // 4) final default: windows (explicit as requested)
  window.__albums_detectedPlatform = 'windows';
  updateMethodBadge('windows');
  return 'windows';
}

function updateMethodBadge(text){
  const el = $id('detectedMethod');
  if (!el) return;
  el.textContent = `platform: ${text}`;
}

/* ---------- listDir (multi-fallback) ---------- */
async function listDir(targetDir){
  // pocketList helper
  if (typeof window.pocketList === 'function') {
    try { return await window.pocketList(targetDir); } catch(e){ console.warn('pocketList failed', e); }
  }

  // pocketserver-api list
  try {
    const r = await fetch(`/pocketserver-api/list?q=${encodeURIComponent(targetDir)}`, { credentials: 'include' });
    if (r && r.ok) {
      const txt = await r.text();
      try {
        const parsed = JSON.parse(txt);
        return parsed.map(item => typeof item === 'string' ? normalizePath(item) : normalizePath(item.name || String(item)));
      } catch(e){
        const lines = txt.split(/\r?\n/).map(l=>l.trim()).filter(Boolean);
        if (lines.length) return lines.map(normalizePath);
      }
    }
  } catch(e){ console.warn('pocketserver list failed', e); }

  // fallback: fetch folder HTML and parse anchors
  try {
    const r2 = await fetch(targetDir, { cache:'no-store' });
    if (r2 && r2.ok) {
      const html = await r2.text();
      const doc = new DOMParser().parseFromString(html,'text/html');
      const anchors = Array.from(doc.querySelectorAll('a[href]')).map(a => a.getAttribute('href'));
      const resolved = anchors.map(h => { try { return new URL(h, location.origin + targetDir).pathname; } catch(e) { return normalizePath(h); } }).map(normalizePath).filter(Boolean);
      if (resolved.length) return resolved;
    }
  } catch(e){ /* ignore */ }

  return [];
}

function normalizePath(s){ if (!s) return ''; s = String(s).replace(/\\/g,'/'); if (!s.startsWith('/')) s = '/' + s; return s; }
function basenameFromPath(p){ if (!p) return ''; const parts = p.split('/').filter(Boolean); return parts.length ? parts[parts.length-1] : p; }

/* ---------- upload primitives (same multi-strategy used elsewhere) ---------- */

/* pocketUpload: multipart POST to /pocketserver-api/upload */
async function pocketUpload(name, targetDir, blobOrFile){
  try {
    let fileToSend = blobOrFile;
    if (!(blobOrFile instanceof Blob)) fileToSend = new Blob([blobOrFile || ''], { type: 'application/octet-stream' });
    const fd = new FormData();
    fd.append('files[]', fileToSend, name);
    fd.append('targetDir', targetDir);
    const r = await fetch('/pocketserver-api/upload', { method:'POST', body: fd, credentials:'include' });
    console.log('[pocketUpload]', targetDir, name, '->', r.status);
    return r.ok;
  } catch(e){ console.warn('pocketUpload error', e); return false; }
}

/* pocketReplace: upload temp then replace */
async function pocketReplace(name, targetDir, blob){
  try {
    const temp = name + '.__new__';
    const okTemp = await pocketUpload(temp, targetDir, blob);
    if (!okTemp) { console.warn('pocketReplace temp failed'); return false; }
    // attempt to delete original then upload real
    try { await pocketDelete(targetDir + name); } catch(e){}
    const ok = await pocketUpload(name, targetDir, blob);
    try { await pocketDelete(targetDir + temp); } catch(e){}
    return ok;
  } catch(e){ console.warn('pocketReplace error', e); return false; }
}

/* pocketDelete: use pocketserver-api/command */
async function pocketDelete(fullPath){
  try {
    const res = await fetch('/pocketserver-api/command', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ command:'delete', paths:[fullPath] }), credentials:'include' });
    console.log('[pocketDelete]', fullPath, '->', res.status);
    return res.ok;
  } catch(e){ console.warn('pocketDelete failed', e); return false; }
}

/* apiUpload: FormData PUT to /api/file/upload?path= */
async function apiUpload(targetDir, blob, filename){
  try {
    const fd = new FormData();
    fd.append('files[]', blob, filename);
    const r = await fetch(`/api/file/upload?path=${encodeURIComponent(targetDir)}`, { method:'PUT', body: fd, credentials:'include' });
    console.log('[apiUpload]', targetDir, filename, '->', r.status);
    return r.ok;
  } catch(e){ console.warn('apiUpload failed', e); return false; }
}

/* putFileByPUT: attempt direct PUT to a constructed path */
async function putFileByPUT(fullPath, blob){
  try {
    // try raw first
    try {
      const r = await fetch(fullPath, { method:'PUT', body: blob, credentials:'include' });
      console.log('[putFileByPUT] try1', fullPath, '->', r.status);
      if (r.ok) return true;
    } catch(e){ console.warn('put try1 failed', e); }
    // try with ./ prefix
    try {
      const r2 = await fetch(`.${fullPath}`, { method:'PUT', body: blob, credentials:'include' });
      console.log('[putFileByPUT] try2', '.'+fullPath, '->', r2.status);
      if (r2.ok) return true;
    } catch(e){ console.warn('put try2 failed', e); }
    return false;
  } catch(e){ console.warn('putFileByPUT error', e); return false; }
}

/* high-level uploadFileToPath — order depends on detected platform (windows default) */
async function uploadFileToPath(targetDir, filename, fileBlob){
  const platform = (await detectPlatform()).toLowerCase();
  console.log('[uploadFileToPath] platform', platform, 'targetDir', targetDir, 'filename', filename);
  // Helper to show chosen method
  function showMethod(m){ console.log('[upload] method ->', m); toast(`${m} → ${filename}`, 1200); }

  // iOS / iPhone branch: pocket helpers are favored
  if (platform.includes('iphone') || platform.includes('ios')) {
    showMethod('pocketReplace/pocketUpload');
    if (typeof window.pocketReplace === 'function') {
      try { if (await window.pocketReplace(filename, targetDir, fileBlob)) return true; } catch(e){ console.warn(e); }
    }
    if (await pocketReplace(filename, targetDir, fileBlob)) return true;
    if (await pocketUpload(filename, targetDir, fileBlob)) return true;
    // fallback to direct PUT
    if (await putFileByPUT(targetDir + encodeURIComponent(filename), fileBlob)) return true;
    return false;
  }

  // Android branch: apiUpload preferred
  if (platform.includes('android')) {
    showMethod('apiUpload → putFile → pocketUpload');
    if (await apiUpload(targetDir, fileBlob, filename)) return true;
    if (await putFileByPUT(targetDir + encodeURIComponent(filename), fileBlob)) return true;
    if (await pocketUpload(filename, targetDir, fileBlob)) return true;
    return false;
  }

  // WINDOWS or default branch: try direct PUT first (explicit requested default)
  showMethod('putFileByPUT → apiUpload → pocketUpload');
  if (await putFileByPUT(targetDir + encodeURIComponent(filename), fileBlob)) return true;
  if (await apiUpload(targetDir, fileBlob, filename)) return true;
  if (await pocketUpload(filename, targetDir, fileBlob)) return true;
  return false;
}

/* deletePathImpl: prefer pocketCommand / pocketDelete */
async function deletePathImpl(fullPath){
  if (typeof window.pocketCommand === 'function') {
    try { const res = await window.pocketCommand({ command: 'delete', paths: [ fullPath ] }); return !!res; } catch(e){ console.warn('pocketCommand failed', e); }
  }
  return await pocketDelete(fullPath);
}

/* ---------- metadata JSON helpers ---------- */
async function fetchJson(filename){
  try {
    const r = await fetch(`./Profiles/${filename}?t=${Date.now()}`, { cache:'no-store' });
    if (!r.ok) return null;
    return await r.json();
  } catch(e){ return null; }
}
async function saveJson(filename, data){
  const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
  // Try PUT to ./Profiles/filename first (windows)
  try {
    if (await putFileByPUT(`/Profiles/${encodeURIComponent(filename)}`, blob)) return true;
  } catch(e){ console.warn('saveJson putFileByPUT failed', e); }
  // fallback to pocketUpload into /Profiles/
  try {
    if (await pocketUpload(filename, '/Profiles/', blob)) return true;
  } catch(e){ console.warn('saveJson pocketUpload failed', e); }
  // fallback to apiUpload (if server accepts)
  try {
    if (await apiUpload('/Profiles/', blob, filename)) return true;
  } catch(e){ console.warn('saveJson apiUpload failed', e); }
  return false;
}

/* ---------- library & album management ---------- */
async function buildProfiles(){
  const rootList = await listDir(AlbumsRoot);
  const candidates = new Set();
  (rootList || []).forEach(entry => {
    const s = normalizePath(String(entry));
    const parts = s.split('/').filter(Boolean);
    if (parts[0] === 'Albums' && parts[1]) candidates.add(parts[1]);
    else if (parts.length >= 1) candidates.add(parts[0]);
  });
  if (!candidates.has(activeProfile)) candidates.add(activeProfile);
  profiles = Array.from(candidates).sort();
  renderProfilesBar();
}

function renderProfilesBar(){
  $id('activeProfileLabel').textContent = activeProfile;
  try { $id('activeProfileIcon').src = `./Profiles/${activeProfile}.jpg`; } catch(e){}
  const existing = $id('profileSelectMini');
  if (existing) existing.remove();
  const mini = document.createElement('div'); mini.id='profileSelectMini'; mini.style.marginTop='10px';
  profiles.forEach(p => {
    const btn = document.createElement('button');
    btn.textContent = p;
    btn.style.margin='3px';
    btn.style.padding='6px';
    btn.style.borderRadius='6px';
    btn.style.border='1px solid rgba(255,255,255,0.03)';
    btn.style.background = p === activeProfile ? 'linear-gradient(90deg,var(--accent),#2fbfda)' : 'transparent';
    btn.onclick = ()=> setActiveProfile(p);
    mini.appendChild(btn);
  });
  document.querySelector('.sidebar').appendChild(mini);
}

async function setActiveProfile(name){
  activeProfile = name;
  persistProfile(name);
  $id('activeProfileName').textContent = name;
  $id('activeProfileLabel').textContent = name;
  await refreshAll();
}

async function loadLibrary(){
  const dir = `${AlbumsRoot}${activeProfile}/`;
  const listing = await listDir(dir) || [];
  const files = [];
  (listing || []).forEach(entry => {
    const bn = basenameFromPath(entry);
    if (IMAGE_RE.test(bn)) {
      const p = entry.startsWith('/') ? entry : (dir + bn);
      files.push(p);
    }
  });
  masterLibrary = files;
}

async function loadAlbumMetadata(){
  const data = await fetchJson(`${activeProfile}-albums.json`);
  customAlbums = Array.isArray(data) ? data : [];
  if (!customAlbums.find(a=>a.slug==='unsorted')) customAlbums.unshift({ name: 'Unsorted', slug: 'unsorted', owner: activeProfile });
}

function renderSidebarAlbums(){
  const myList = $id('my-albums-list'); myList.innerHTML = '';
  const sharedList = $id('shared-albums-list'); sharedList.innerHTML = '';
  customAlbums.forEach(album => {
    const div = document.createElement('div');
    div.className = `nav-item ${ (album.slug === (currentView||'all') ? 'active' : '') }`;
    div.onclick = ()=> setView(album.slug);
    div.textContent = `📂 ${album.name}`;
    if (!album.owner || album.owner === activeProfile) myList.appendChild(div);
    else sharedList.appendChild(div);
  });
}

/* ---------- rendering grid ---------- */
async function setView(view){
  currentView = view;
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  if(view === 'all') $id('nav-all').classList.add('active');
  $id('viewTitle').textContent = (view === 'all') ? 'All Photos' : (customAlbums.find(a=>a.slug===view)?.name || 'Album');
  await renderGridForView(view);
}

async function renderGridForView(view){
  const grid = $id('photos'); grid.innerHTML = '';
  let displayList = [];
  if (view === 'all') displayList = masterLibrary.slice();
  else if (view === 'unsorted') {
    const assigned = new Set();
    for (const al of customAlbums) {
      if (al.slug === 'unsorted') continue;
      const arr = await fetchJson(`${activeProfile}-album-${al.slug}.json`) || [];
      arr.forEach(n => assigned.add(n));
    }
    displayList = masterLibrary.filter(p => !assigned.has(basenameFromPath(p)));
  } else {
    const arr = await fetchJson(`${activeProfile}-album-${view}.json`) || [];
    displayList = arr.map(n => `${AlbumsRoot}${activeProfile}/${n}`);
  }

  if (!displayList.length) { grid.innerHTML = `<div class="empty muted">No photos here.</div>`; return; }

  displayList.forEach(path => {
    const filename = basenameFromPath(path);
    const card = document.createElement('div'); card.className='photo-card';
    const img = document.createElement('img'); img.src = path; img.alt = filename;
    img.addEventListener('error', function tryEnc(){
      if (!this._tried) { this._tried = true; this.src = encodeURI(path); }
    });
    card.appendChild(img);

    const actions = document.createElement('div'); actions.className='card-actions';
    const left = document.createElement('div');

    const shareBtn = document.createElement('button'); shareBtn.className='action-btn'; shareBtn.textContent='Share';
    shareBtn.onclick = async (ev) => {
      ev.stopPropagation();
      toast('Sharing (attempt).');
      try {
        const blob = await fetch(img.src, { cache:'no-store' }).then(r=>r.blob());
        const targetDir = `${AlbumsRoot}shared/`;
        const targetName = `${activeProfile}-${filename}`;
        const ok = await uploadFileToPath(targetDir, targetName, blob);
        if (ok) { toast('Shared'); await refreshAll(); } else toast('Share failed (see console)');
      } catch(e){ console.warn(e); toast('Share failed'); }
    };
    left.appendChild(shareBtn);

    const addBtn = document.createElement('button'); addBtn.className='action-btn'; addBtn.textContent='＋';
    addBtn.title='Add to album';
    addBtn.onclick = (ev)=> { ev.stopPropagation(); addToAlbumDialog(filename); };
    left.appendChild(addBtn);

    const delBtn = document.createElement('button'); delBtn.className='action-btn ghost'; delBtn.textContent='🗑️';
    delBtn.onclick = async (ev) => {
      ev.stopPropagation();
      if (!confirm('Delete this photo?')) return;
      const ok = await deletePathImpl(`${AlbumsRoot}${activeProfile}/${filename}`);
      if (ok) { toast('Deleted'); await refreshAll(); } else toast('Delete failed');
    };

    actions.appendChild(left);
    actions.appendChild(delBtn);
    card.appendChild(actions);
    img.onclick = ()=> window.open(path, '_blank');
    grid.appendChild(card);
  });
}

/* ---------- album create & add ---------- */
function createAlbumModal(){
  $id('modalHeading').textContent = 'Create New Album';
  $id('modalInput').value = '';
  $id('modalOverlay').style.display = 'flex';
  $id('modalSaveBtn').onclick = async ()=>{
    const name = $id('modalInput').value.trim();
    if (!name) return alert('Give the album a name');
    const slug = name.toLowerCase().replace(/[^a-z0-9\-_\s]/gi,'').replace(/\s+/g,'-');
    if (!slug) return alert('Invalid album name');
    customAlbums.push({ name, slug, owner: activeProfile });
    const ok = await saveJson(`${activeProfile}-albums.json`, customAlbums);
    if (!ok) toast('Could not persist album metadata (save not implemented)');
    await saveJson(`${activeProfile}-album-${slug}.json`, []);
    closeModal();
    await refreshAll();
  };
}
function closeModal(){ $id('modalOverlay').style.display='none'; }

async function addToAlbumDialog(filename){
  const names = customAlbums.map(a=>a.name);
  if (!names.length) return toast('Create an album first');
  const choice = prompt('Add to which album?\n' + names.join(', '));
  if (!choice) return;
  const album = customAlbums.find(a => a.name.toLowerCase() === choice.toLowerCase() || a.slug === choice);
  if (!album) return toast('Album not found');
  const list = await fetchJson(`${activeProfile}-album-${album.slug}.json`) || [];
  if (!list.includes(filename)) list.push(filename);
  const ok = await saveJson(`${activeProfile}-album-${album.slug}.json`, list);
  if (!ok) toast('Could not save album list (save not implemented)');
  else toast(`Added to ${album.name}`);
  await refreshAll();
}

/* ---------- upload staging ---------- */
function handleUpload(input){
  if (!input.files || input.files.length === 0) return;
  for (const f of input.files) {
    const prev = URL.createObjectURL(f);
    stagedUploads.push({ file: f, previewUrl: prev });
  }
  renderStaged();
  input.value = '';
}
function renderStaged(){
  $id('stagedGrid').innerHTML = '';
  $id('stagedCount').textContent = `${stagedUploads.length} file(s) staged`;
  for (const item of stagedUploads) {
    const div = document.createElement('div'); div.className='staged-tile';
    const img = document.createElement('img'); img.src = item.previewUrl;
    div.appendChild(img);
    $id('stagedGrid').appendChild(div);
  }
}
function clearStaged(){
  stagedUploads.forEach(s=>{ try{ URL.revokeObjectURL(s.previewUrl); }catch(e){} });
  stagedUploads = [];
  renderStaged();
}

/* ---------- commit uploads (uses platform detection + uploadFileToPath) ---------- */
async function commitUploads(){
  if (!stagedUploads.length) return toast('No files staged');
  let albumChoice = currentView === 'all' ? prompt('Target album (leave blank for profile root /Unsorted):') : currentView;
  albumChoice = (albumChoice && albumChoice.trim()) ? albumChoice.trim() : (currentView === 'all' ? 'Unsorted' : currentView);
  const targetDir = `${AlbumsRoot}${activeProfile}/${ albumChoice === 'Unsorted' ? '' : albumChoice + '/' }`;
  let failed = 0;
  for (const it of stagedUploads) {
    const name = it.file.name;
    toast(`Uploading ${name} ...`, 900);
    const ok = await uploadFileToPath(targetDir, name, it.file);
    if (!ok) { failed++; console.warn('upload failed:', name); continue; }
    // update album JSON if needed
    if (albumChoice !== 'Unsorted') {
      const slug = albumChoice.toLowerCase().replace(/\s+/g,'-');
      const arr = await fetchJson(`${activeProfile}-album-${slug}.json`) || [];
      if (!arr.includes(name)) { arr.push(name); await saveJson(`${activeProfile}-album-${slug}.json`, arr); }
    }
  }
  if (failed === 0) toast('Uploads completed');
  else toast(`${failed} upload(s) failed`);
  clearStaged();
  await refreshAll();
}

/* ---------- search filter ---------- */
function filterGrid(q){
  q = (q || '').toLowerCase();
  document.querySelectorAll('.photo-card').forEach(card=>{
    const img = card.querySelector('img');
    const name = (img && img.alt) ? img.alt.toLowerCase() : '';
    card.style.display = name.includes(q) ? '' : 'none';
  });
}

/* ---------- refresh & init ---------- */
async function refreshAll(){
  await buildProfiles();
  await loadLibrary();
  await loadAlbumMetadata();
  renderSidebarAlbums();
  await setView(currentView === 'all' ? 'all' : currentView);
  renderProfilesBar();
}
async function init(){
  $id('activeProfileName').textContent = activeProfile;
  $id('activeProfileLabel').textContent = activeProfile;
  await detectPlatform(); // pre-populate badge
  await refreshAll();
  document.addEventListener('keydown', (e)=>{ if (e.key === 'n' && (document.activeElement.tagName !== 'INPUT')) createAlbumModal(); });
}
init();

/* ---------- debug exports ---------- */
window.AlbumsUI = {
  detectPlatform, listDir, uploadFileToPath, pocketUpload, apiUpload, putFileByPUT, deletePathImpl: pocketDelete,
  fetchJson, saveJson, stagedUploads, commitUploads, refreshAll, setActiveProfile
};
</script>
</body>
</html>
