// ----------------------
// Kids-mode seasons helper
// ----------------------
// URL?I is original mode ---- URL?l is kids mode!
// ----------------------

function normalizeSeasonsArrayInPlace(arr) {
  if (!Array.isArray(arr)) return;

  const urlParams = new URLSearchParams(window.location.search || '');
  const kidsMode = urlParams.has('l');

  for (let i = arr.length - 1; i >= 0; i--) {
    const v = arr[i];
    if (typeof v !== 'string') continue;

    const isAdult = v.indexOf('*') !== -1;
    const cleaned = v.replace(/\*/g, '').trim();

    if (kidsMode && isAdult) {
      arr.splice(i, 1);
    } else {
      arr[i] = cleaned;
    }
  }
}// ----------------------
