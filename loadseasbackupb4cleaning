        // add other mappings here if needed, e.g. "Some Collection": loadSomeCollectionSeasons
    };

    seasons.forEach(season => {
        const seasonDiv = document.createElement("div");
        seasonDiv.className = "folder";

        // construct path using safeName() in case some filenames are slightly different
        const safe = safeName(season);
        const img = document.createElement("img");
        img.alt = season;
        img.src = `./Marvel Movies/${safe}/${safe}.jpg`;

        // fallback poster
        img.onerror = () => {
            img.onerror = null;
            img.src = './Marvel Movies/placeholder.jpg';
        };

        const p = document.createElement("p");
        p.textContent = season;

        seasonDiv.appendChild(img);
        seasonDiv.appendChild(p);

        // Default: open episodes, but handle special collections like Blade Collection
        seasonDiv.addEventListener("click", () => {
            const handler = specialCollections[season];
            if (handler) {
                // If a placeholder episodes entry exists and interferes, remove it
                if (typeof episodes !== "undefined" && episodes && episodes[season]) {
                    delete episodes[season];
                }
                handler();
            } else {
                loadEpisodes(season);
