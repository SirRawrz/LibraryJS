{
  "manifest_version": 3,
  "name": "Music Archiver Local Proxy",
  "version": "0.1.0",
  "description": "MV3 browser relay for the local Music Archiver for LibraryJS self-hosted page.",
  "permissions": [
    "activeTab",
    "downloads",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Music Archiver Relay",
    "default_icon": {
      "16": "icons/idle-16.png",
      "32": "icons/idle-32.png",
      "48": "icons/idle-48.png",
      "128": "icons/idle-128.png"
    }
  }
}