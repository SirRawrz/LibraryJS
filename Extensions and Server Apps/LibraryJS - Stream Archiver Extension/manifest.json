{
  "manifest_version": 3,
  "name": "SelfHosted Stream Archiver",
  "version": "1.7.0",
  "description": "Detects HLS/M3U streams, archives playlist and segment files, and remuxes HLS into a complete MP4 in the browser using Mediabunny when possible.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Stream Archiver"
  },
  "background": {
    "service_worker": "service_worker.js"
  },
  "options_page": "options.html",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "webRequest",
    "webNavigation",
    "alarms",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "bridge.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  }
}
